# OAuth credentials (contains tokens — never commit)
.clasprc.json

# WordPress credentials
.wp-credentials
.sftp-credentials
.mc-credentials
*.credentials.csv

# Google Cloud service-account credentials (used by content/register-library.js)
.gcp-credentials.json

# Local npm install for content/ tooling
content/node_modules/
content/package-lock.json

# Local incremental-deploy manifest (SHA-1 of last-deployed theme files)
.deploy-theme-manifest.json

# Content working files
content/history/
content/*.zip
content/existing-layouts/*.jpg

# Content image assets — live copies live in the WP media library + Drive
# (Content Library canonical archive), git is not a third copy.
content/**/*.jpg
content/**/*.png
marketing/newsletter/images/

# Windows artifacts
nul
jlmops/nul

# Scratch / temp folders (file exchange, screenshots, dumps, node_modules)
exchange/
temp/
jlmops/exchange/
