{
  "files": {
    "exclude": [
      "**/node_modules/**",
      "**/.git/**",
      "**/ComaxProducts.csv",
      "**/*.log",
      "jlmops/SetupConfig.js"
    ],
    "notes": {
      "SetupConfig.js": "Auto-generated - DO NOT EDIT. Edit config/*.json and run generate-config.js instead"
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__claude_ai_Google_Drive__create_file|mcp__claude_ai_Google_Drive__copy_file",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "C:/Users/B/projects/jlmwines/.claude/hooks/require-data-model-read.js"
            ],
            "statusMessage": "Checking DATA_MODEL.md was read this session"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "C:/Users/B/projects/jlmwines/.claude/hooks/content-task-protocol-check.js"
            ],
            "statusMessage": "Checking content-task protocol"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "if [ -n \"$(git status --porcelain 2>/dev/null)\" ]; then git add -A && git commit -q --no-verify -m \"chore(auto): session checkpoint - leave a clean tree for the next session\" >/dev/null 2>&1; fi",
            "timeout": 30,
            "statusMessage": "Auto-committing uncommitted changes"
          }
        ]
      }
    ]
  }
}
